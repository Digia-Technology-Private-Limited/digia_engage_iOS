<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Privacy manifest for the SLIM DigiaEngage.framework (shared-deps build).
  Covers ONLY DigiaEngage's own required-reason API usage:
    - UserDefaults (1C8F.1) : DigiaEngage's own state (submission_reporter.swift)
  Lottie / SDWebImage ship their OWN manifests in their own frameworks
  (they are NOT embedded here), so their entries are not duplicated.
  DigiaEngage does not track users and collects no data types.
-->
<plist version="1.0">
<dict>
	<key>NSPrivacyTracking</key>
	<false/>
	<key>NSPrivacyTrackingDomains</key>
	<array/>
	<key>NSPrivacyCollectedDataTypes</key>
	<array/>
	<key>NSPrivacyAccessedAPITypes</key>
	<array>
		<dict>
			<key>NSPrivacyAccessedAPIType</key>
			<string>NSPrivacyAccessedAPICategoryUserDefaults</string>
			<key>NSPrivacyAccessedAPITypeReasons</key>
			<array>
				<string>1C8F.1</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
