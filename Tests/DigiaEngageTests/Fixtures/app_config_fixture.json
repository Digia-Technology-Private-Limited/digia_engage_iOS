{
  "appSettings": {
    "initialRoute": "samples-list-page"
  },
  "pages": {
    "samples-list-page": {
      "slug": "samples-list-page",
      "uid": "samples-list-page",
      "layout": {
        "root": {
          "type": "fw/scaffold",
          "props": {
            "scaffoldBackgroundColor": "#FFFFFF",
            "enableSafeArea": true
          },
          "children": {
            "appBar": [],
            "body": [
              {
                "type": "digia/column",
                "props": {
                  "spacing": 8
                },
                "children": [
                  {
                    "type": "digia/text",
                    "props": {
                      "text": "Countries (Dynamic Data Example)"
                    }
                  },
                  {
                    "type": "digia/container",
                    "props": {
                      "padding": 12,
                      "color": "#a39cdd"
                    },
                    "children": [
                      {
                        "type": "digia/text",
                        "props": {
                          "text": "Container Child"
                        }
                      }
                    ]
                  },
                  {
                    "type": "digia/row",
                    "props": {
                      "spacing": 10
                    },
                    "children": [
                      {
                        "type": "digia/button",
                        "props": {
                          "text": {
                            "text": "Tap Me"
                          }
                        }
                      },
                      {
                        "type": "digia/image",
                        "props": {
                          "imageSrc": "https://example.com/image.png"
                        }
                      }
                    ]
                  },
                  {
                    "type": "digia/text",
                    "props": {
                      "text": "Load Joke Example"
                    }
                  }
                ]
              }
            ]
          }
        }
      }
    },
    "country-detail": {
      "slug": "country-detail",
      "uid": "country-detail"
    }
  },
  "components": {
    "hero-card": {
      "uid": "hero-card"
    }
  },
  "rest": {
    "baseUrl": "https://app.digia.tech/hydrator/api"
  },
  "theme": {
    "colors": {
      "light": {
        "primary": "#a39cdd"
      }
    }
  },
  "version": 7
}
